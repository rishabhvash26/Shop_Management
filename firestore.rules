rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // The frontend never talks to Firestore directly - all reads/writes go
    // through the Express API (functions/), which uses the Admin SDK and
    // always bypasses these rules. Direct client access is denied entirely.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
